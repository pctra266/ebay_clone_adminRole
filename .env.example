# ============================================================
# ⚠️  HƯỚNG DẪN CHO ĐỒNG ĐỘI
# 1. Copy file này: cp .env.example .env
# 2. Điền thông tin của bạn vào file .env
# 3. KHÔNG commit file .env lên GitHub
# ============================================================

# ---- SQL Server ----
# Password phải >= 8 ký tự, có chữ hoa, chữ thường, số, ký tự đặc biệt
SA_PASSWORD=YourStrongPassword123!

# ---- JWT ----
# Chuỗi bí mật ít nhất 32 ký tự, tự đặt tùy ý
JWT_KEY=YourSuperSecretJwtKeyAtLeast32Chars!

# ---- Email (Gmail App Password) ----
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# ---- App Environment ----
ASPNETCORE_ENVIRONMENT=Development
